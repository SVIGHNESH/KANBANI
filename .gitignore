# ──────────────────────────────────────────────────────────────
#  Node / frontend (Vite + React)
# ──────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ──────────────────────────────────────────────────────────────
#  Rust / Tauri backend
# ──────────────────────────────────────────────────────────────
# Cargo build output
target/
# Tauri auto-generated capability schemas
gen/schemas/
# Bundled installers / binaries
*.AppImage
*.deb
*.rpm

# ──────────────────────────────────────────────────────────────
#  Logs & debug
# ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ──────────────────────────────────────────────────────────────
#  Environment & secrets
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────
#  Local database files (app data is created at runtime)
# ──────────────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────────────────────
#  Editor / IDE
# ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ──────────────────────────────────────────────────────────────
#  OS cruft
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
