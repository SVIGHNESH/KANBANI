{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KANBANI",
  "version": "0.1.0",
  "identifier": "com.vighnesh.kanban",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KANBANI",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Vighnesh Shukla",
    "copyright": "© Vighnesh Shukla",
    "shortDescription": "A native local Kanban board",
    "longDescription": "KANBANI — a native desktop Kanban board with local SQLite storage. Created by Vighnesh Shukla.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
